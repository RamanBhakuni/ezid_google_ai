# Copy this file to ".env" and fill in your local Postgres credentials.

# Postgres connection (local)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ezid

# Port the API server listens on
PORT=4000

# Resend transactional email (https://resend.com)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=
# Sender address. For testing without a verified domain, Resend allows
# "onboarding@resend.dev" (only delivers to YOUR own Resend account email).
# For real use, verify your domain and use e.g. "EZID <noreply@yourdomain.com>".
EMAIL_FROM=EZID <onboarding@resend.dev>

# Postgres-native auth
# Use a long random string in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=dev_change_me_to_a_long_random_string_in_production
# Public URL of the frontend, used to build email links
APP_URL=http://localhost:3000
